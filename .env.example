# ============================================================================
# MangaZine Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual API keys
#
# Usage:
#   1. Copy: cp .env.example .env (Linux/Mac) or copy .env.example .env (Windows)
#   2. Edit .env and add your API keys
#   3. Configure which providers to use (see below)

# ----------------------------------------------------------------------------
# Provider Selection
# ----------------------------------------------------------------------------
# Choose which LLM and Image providers to use
# LLM options: gemini, openai
# Image options: gemini, openai, seedream

LLM_PROVIDER=gemini
IMAGE_PROVIDER=gemini

# ----------------------------------------------------------------------------
# API Keys (only fill in keys for providers you're using)
# ----------------------------------------------------------------------------

# Google GenAI (required if using gemini provider)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI (required if using openai provider)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ByteDance Seedream/Doubao (required if using seedream provider)
# Get yours at: https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
SEEDREAM_API_KEY=your-seedream-api-key-here

# ----------------------------------------------------------------------------
# Model Configuration (optional overrides)
# ----------------------------------------------------------------------------

# Gemini models
# GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
# GEMINI_IMAGE_DRAFT_MODEL=gemini-3.1-flash-image-preview
# GEMINI_IMAGE_FINAL_MODEL=gemini-3-pro-image-preview

# OpenAI models
# OPENAI_TEXT_MODEL=gpt-4o
# OPENAI_IMAGE_MODEL=dall-e-3

# Seedream models
# SEEDREAM_IMAGE_MODEL=seedream-v1
# SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ----------------------------------------------------------------------------
# Output Configuration
# ----------------------------------------------------------------------------

# Create unique timestamped folders for each project (recommended: true)
USE_UNIQUE_PROJECT_FOLDERS=true

# ----------------------------------------------------------------------------
# Generation Parameters (optional)
# ----------------------------------------------------------------------------

# DEFAULT_TEMPERATURE=0.7
# DEFAULT_MAX_TOKENS=8192
